#!/bin/bash
# This script installs lefthook for managing git hooks (formatting, linting).
# Runs once per installation.
# Only runs in devcontainer/codespace environments OR on dev servers (SVLDEV*).
# Skipped on light servers (SVL*).

set -e

# Set MISE_YES=1 to auto-accept trust prompts during installation
# This prevents mise from hanging in non-interactive environments (Codespaces, CI)
export MISE_YES=1

# Check if we're in a git repository - if not, try to use chezmoi source directory
if ! git rev-parse --git-dir >/dev/null 2>&1; then
    # Try to use the chezmoi source directory if it's a git repository
    if [ -d "{{ .chezmoi.sourceDir }}/.git" ]; then
        echo "📁 Changing to chezmoi source directory..."
        cd "{{ .chezmoi.sourceDir }}"
    else
        echo "ℹ️  Skipping lefthook installation (not in a git repository)"
        exit 0
    fi
fi

# {{ if eq .installType "light" }}
# {{   if not (or .devcontainer .codespaces) }}
echo "ℹ️  Skipping lefthook installation (light server mode)"
exit 0
# {{   end }}
# {{ end }}

if command -v lefthook >/dev/null 2>&1; then
    echo "✅ lefthook already installed"
    exit 0
fi

# {{ if or .devcontainer .codespaces }}
echo "🐳 Detected devcontainer/codespace environment - installing lefthook..."
# {{ else if eq .installType "full" }}
echo "📦 Installing lefthook on dev server..."
# {{ end }}

echo "📦 Installing lefthook..."

# Prefer mise (already managed by this repo) so the lefthook version
# matches .mise.toml. Fall back to brew on macOS as a convenience.
if command -v mise >/dev/null 2>&1; then
    (cd "{{ .chezmoi.sourceDir }}" && mise install lefthook)
# {{ if eq .chezmoi.os "darwin" }}
elif command -v brew >/dev/null 2>&1; then
    brew install lefthook
# {{ end }}
else
    echo "⚠️  mise is not installed; cannot install lefthook automatically."
    echo "💡 Install mise (https://mise.jdx.dev/) and re-run, or install lefthook manually."
    exit 0
fi

echo "✅ lefthook installed successfully!"

# Auto-enable hooks in devcontainer/codespace/dev server environments
# {{ if or .devcontainer .codespaces (eq .installType "full") }}
if [ -d "{{ .chezmoi.sourceDir }}/.git" ] || git rev-parse --git-dir >/dev/null 2>&1; then
    echo "🔗 Enabling lefthook hooks..."
    cd "{{ .chezmoi.sourceDir }}" && (lefthook install || mise exec -- lefthook install)
    echo "✅ Lefthook hooks enabled!"
else
    echo "💡 To enable hooks later, run: lefthook install"
fi
# {{ else }}
echo "💡 To enable hooks, run: lefthook install"
# {{ end }}
