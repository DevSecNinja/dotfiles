[user]
	name = {{ .name }}
	email = {{ .email }}

[core]
	editor = vim
	autocrlf = input
	excludesfile = ~/.config/git/ignore
# {{ if .wsl }}
	sshCommand = ssh.exe
# {{ else if eq .chezmoi.os "windows" }}
	sshCommand = "C:/Windows/System32/OpenSSH/ssh.exe"
# {{ end }}

[commit]
	template = ~/.gitmessage
	cleanup = strip

[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE

[mergetool "vscode"]
	cmd = code --wait $MERGED

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	default = simple
	autoSetupRemote = true

[color]
	ui = auto

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	unstage = reset HEAD --
	last = log -1 HEAD
	visual = log --oneline --graph --all
	amend = commit --amend --no-edit
	config-list = config --list --show-origin
	ignored = ls-files --ignored --exclude-standard --others
	# Auto-stash, checkout, then pop the stash (mirrors merge/rebase autoStash).
	# Usage: git sco <branch>
	sco = "!f() { \
		if git diff-index --quiet HEAD -- && [ -z \"$(git ls-files --others --exclude-standard)\" ]; then \
			git checkout \"$@\"; \
		else \
			msg=\"auto-stash before checkout $*\"; \
			git stash push --include-untracked -m \"$msg\" >/dev/null && \
			git checkout \"$@\" && \
			git stash pop; \
		fi; \
	}; f"

# {{ if and (eq .chezmoi.os "darwin") (not .codespaces) }}
[credential]
	helper = osxkeychain
# {{ else if eq .chezmoi.os "windows" }}
[credential]
	helper = manager
# {{ else if and (eq .chezmoi.os "linux") (not .codespaces) }}
[credential]
	helper = cache
# {{ end }}

[diff]
	colorMoved = zebra
	tool = vscode

[merge]
	conflictstyle = diff3
	autoStash = true
	tool = vscode

[rebase]
	autoStash = true

[apply]
	whitespace = nowarn
{{ if .useYubiKey }}
# SSH-based commit signing using the FIDO2 SSH key generated by `yk-enroll`
# (see docs/yubikey.md). Activated only when chezmoi `useYubiKey` is true.
#
# `user.signingkey` is a single path — we pick the first per-serial pubkey
# we find (yk-enroll writes id_*_sk_<serial>.pub), falling back to the
# legacy un-suffixed name. `allowed_signers` lists *all* pubkeys so any
# plugged-in YubiKey verifies.
{{- $skEdSerials := glob (joinPath .chezmoi.homeDir ".ssh" "id_ed25519_sk_*.pub") -}}
{{- $skEcSerials := glob (joinPath .chezmoi.homeDir ".ssh" "id_ecdsa_sk_*.pub") -}}
{{- $skEd := joinPath .chezmoi.homeDir ".ssh" "id_ed25519_sk.pub" -}}
{{- $skEc := joinPath .chezmoi.homeDir ".ssh" "id_ecdsa_sk.pub" -}}
{{- $signingKey := "" -}}
{{- if gt (len $skEdSerials) 0 -}}{{- $signingKey = index $skEdSerials 0 -}}
{{- else if stat $skEd -}}{{- $signingKey = $skEd -}}
{{- else if gt (len $skEcSerials) 0 -}}{{- $signingKey = index $skEcSerials 0 -}}
{{- else if stat $skEc -}}{{- $signingKey = $skEc -}}
{{- end }}
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
{{- if $signingKey }}
[user]
	signingkey = {{ $signingKey }}
[commit]
	gpgsign = true
[tag]
	gpgsign = true
{{- else }}
# No FIDO2 SSH pubkey found yet. Run `yk-enroll` then re-run `chezmoi apply`
# to enable signing.
{{- end }}
{{ end -}}
