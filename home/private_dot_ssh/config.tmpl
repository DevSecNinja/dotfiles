{{- if not .useYubiKey }}
# Adds any 1Password configured hosts (optional, enable via Developer -> Generate SSH config file with bookmarked hosts)
Include ~/.ssh/1Password/config
{{- end }}
{{ if and .privateDomain (not .isWork) -}}

# Development Server
Host svldev.{{ .privateDomain }}
    HostName svldev.{{ .privateDomain }}
    # Required for pulling Git repos with SSH password manager feature
    ForwardAgent yes

# NAS Server
Host svlnas.{{ .privateDomain }}
    HostName svlnas.{{ .privateDomain }}
    User truenas_admin
    # Required for pulling Git repos with SSH password manager feature
    ForwardAgent yes

# External Azure Server
Host svlazext.{{ .privateDomain }}
    HostName svlazext.{{ .privateDomain }}

# External Azure Public Server
Host svlazextpub.{{ .privateDomain }}
    HostName svlazextpub.{{ .privateDomain }}

{{ end -}}
Host *
    User {{ .username }}
{{- if .useYubiKey }}
    AddKeysToAgent yes
    # Hardware-backed FIDO2 SSH key generated by `yk-ssh-new` (see docs/yubikey.md).
    # Resident copies on the YubiKey can be reloaded with `ssh-add -K`.
    IdentityFile ~/.ssh/id_ed25519_sk
    IdentityFile ~/.ssh/id_ecdsa_sk
{{- else if eq .chezmoi.os "darwin" }}
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- end }}
