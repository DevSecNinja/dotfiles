{{- /* On a fresh machine the YubiKey FIDO2 key files don't exist yet. We
       only emit IdentityFile lines for keys that are actually present, and
       we keep the 1Password fallback path until at least one resident key
       has been pulled down (`yk-ssh-load`) — otherwise the migration would
       lock you out of `git@github.com` until the keys exist.
       The per-serial files (`id_*_sk_<serial>`) come from `yk-enroll`.
       OpenSSH does not glob IdentityFile, so we enumerate via the chezmoi
       `glob` template function. */}}
{{- $skEd := joinPath .chezmoi.homeDir ".ssh" "id_ed25519_sk" -}}
{{- $skEc := joinPath .chezmoi.homeDir ".ssh" "id_ecdsa_sk" -}}
{{- $skEdSerials := glob (joinPath .chezmoi.homeDir ".ssh" "id_ed25519_sk_*") -}}
{{- $skEcSerials := glob (joinPath .chezmoi.homeDir ".ssh" "id_ecdsa_sk_*") -}}
{{- /* Filter out *.pub from the glob results. */ -}}
{{- $skEdSerialsKeys := list -}}
{{- range $skEdSerials -}}
{{-   if not (hasSuffix ".pub" .) -}}
{{-     $skEdSerialsKeys = append $skEdSerialsKeys . -}}
{{-   end -}}
{{- end -}}
{{- $skEcSerialsKeys := list -}}
{{- range $skEcSerials -}}
{{-   if not (hasSuffix ".pub" .) -}}
{{-     $skEcSerialsKeys = append $skEcSerialsKeys . -}}
{{-   end -}}
{{- end -}}
{{- $hasSkKey := or (stat $skEd) (stat $skEc) (gt (len $skEdSerialsKeys) 0) (gt (len $skEcSerialsKeys) 0) -}}
{{- if and (not .useYubiKey) (not $hasSkKey) }}
# Adds any 1Password configured hosts (optional, enable via Developer -> Generate SSH config file with bookmarked hosts)
Include ~/.ssh/1Password/config
{{- else if and .useYubiKey (not $hasSkKey) }}
# YubiKey is enabled in chezmoi but no resident FIDO2 key files have been
# pulled down yet — keep the 1Password fallback so SSH still works.
# Run `yk-ssh-new` (new key) or `yk-ssh-load` (existing resident key) and
# re-run `chezmoi apply` to switch over.
Include ~/.ssh/1Password/config
{{- end }}
{{ if and .privateDomain (not .isWork) -}}

# Development Server
Host svldev.{{ .privateDomain }}
    HostName svldev.{{ .privateDomain }}
    # Required for pulling Git repos with SSH password manager feature
    ForwardAgent yes

# NAS Server
Host svlnas.{{ .privateDomain }}
    HostName svlnas.{{ .privateDomain }}
    User truenas_admin
    # Required for pulling Git repos with SSH password manager feature
    ForwardAgent yes

# External Azure Server
Host svlazext.{{ .privateDomain }}
    HostName svlazext.{{ .privateDomain }}

# External Azure Public Server
Host svlazextpub.{{ .privateDomain }}
    HostName svlazextpub.{{ .privateDomain }}

{{ end -}}
Host *
    User {{ .username }}
{{- if and .useYubiKey $hasSkKey }}
    # Hardware-backed FIDO2 SSH key generated by `yk-ssh-new` / `yk-enroll`
    # (see docs/yubikey.md). Resident copies on the YubiKey can be reloaded
    # with `ssh-add -K`. Per-serial files come from `yk-enroll`.
    #
    # NB: We deliberately do NOT set `AddKeysToAgent yes` for FIDO2 (`*-sk`)
    # keys. The private key never leaves the YubiKey, so the agent has
    # nothing to cache except the handle. With `verify-required` set, every
    # signing op needs a fresh PIN — but ssh-agent (especially on macOS)
    # cannot re-prompt for the FIDO2 PIN, so subsequent signs fail with
    # `agent refused operation`. Letting OpenSSH talk to the YubiKey
    # directly each time keeps the touch + PIN dance interactive.
    IdentitiesOnly yes
{{- if stat $skEd }}
    IdentityFile ~/.ssh/id_ed25519_sk
{{- end }}
{{- if stat $skEc }}
    IdentityFile ~/.ssh/id_ecdsa_sk
{{- end }}
{{- range $skEdSerialsKeys }}
    IdentityFile {{ . }}
{{- end }}
{{- range $skEcSerialsKeys }}
    IdentityFile {{ . }}
{{- end }}
{{- else if eq .chezmoi.os "darwin" }}
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- end }}
