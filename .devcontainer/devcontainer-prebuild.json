{
    "name": "dotfiles-prebuild",
    // Build config used ONLY by the devcontainer-prebuild workflow to create the prebuilt image.
    // The main devcontainer.json references the resulting image by name.
    // IMPORTANT: Features here MUST match devcontainer.json exactly (same versions) to avoid
    // re-downloading features at container startup. Mismatches force feature reinstallation.
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "DOTFILES_DEVCONTAINER_VERSION": "${localEnv:DOTFILES_DEVCONTAINER_VERSION}",
            "DOTFILES_DEVCONTAINER_REVISION": "${localEnv:DOTFILES_DEVCONTAINER_REVISION}"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/git-lfs:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/powershell:2": {
            "modules": "Pester==5.7.1"
        },
        "ghcr.io/devcontainers/features/github-cli:1": {
            "version": "latest"
        }
    },
    // Baked into the image's devcontainer.metadata label so EVERY repo using
    // this image inherits it with no per-repo devcontainer.json change. Forwards
    // the GitHub Copilot CLI / gh tokens from the host running the Dev Containers
    // backend (for Remote-SSH that is the VS Code Server on the dev server, which
    // gets them from the copilot-ssh-proxy remote.SSH.path helper) into the
    // container. Resolves to empty (harmless, treated as unset) where the tokens
    // aren't present, e.g. local/Codespaces. See dotfiles docs/copilot-cli.md.
    "remoteEnv": {
        "COPILOT_GITHUB_TOKEN": "${localEnv:COPILOT_GITHUB_TOKEN}",
        "GH_TOKEN": "${localEnv:GH_TOKEN}"
    },
    "remoteUser": "vscode"
}
