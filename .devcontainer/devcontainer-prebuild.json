{
    "name": "dotfiles-prebuild",
    // Build config used ONLY by the devcontainer-prebuild workflow to create the prebuilt image.
    // The main devcontainer.json references the resulting image by name.
    // IMPORTANT: Features here MUST match devcontainer.json exactly (same versions) to avoid
    // re-downloading features at container startup. Mismatches force feature reinstallation.
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "DOTFILES_DEVCONTAINER_VERSION": "${localEnv:DOTFILES_DEVCONTAINER_VERSION}",
            "DOTFILES_DEVCONTAINER_REVISION": "${localEnv:DOTFILES_DEVCONTAINER_REVISION}"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/git-lfs:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/powershell:2": {
            "modules": "Pester==5.7.1"
        },
        "ghcr.io/devcontainers/features/github-cli:1": {
            "version": "latest"
        }
    },
    "remoteUser": "vscode"
}
