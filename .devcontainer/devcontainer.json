{
  "name": "dotfiles",
  // Prebuilt image with dotfiles tools (fish, vim, brew, mise, etc.) pre-installed
  // Built by .github/workflows/devcontainer-prebuild.yaml from Dockerfile
  // chezmoi config is removed after prebuild so postCreateCommand re-initializes
  // fresh, correctly detecting the runtime environment (CI, Codespaces, etc.)
  "image": "ghcr.io/devsecninja/dotfiles-devcontainer:latest@sha256:e0d4f3c520c034fc1ad17273fbdf53b553e46c0fbfe1651b0fc8c493550f6946",
  "features": {
    "ghcr.io/devcontainers/features/git-lfs:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:2": {
      "modules": "Pester==5.7.1"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "pspester.pester-test"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.eol": "\n",
        "terminal.integrated.defaultProfile.linux": "fish"
      }
    }
  },
  "postCreateCommand": "./home/install.sh",
  "remoteUser": "vscode"
}
