{
  "name": "dotfiles",
  // Prebuilt image with dotfiles tools (fish, vim, brew, mise, etc.) pre-installed
  // Built by .github/workflows/devcontainer-prebuild.yaml from Dockerfile
  // chezmoi config is removed after prebuild so postCreateCommand re-initializes
  // fresh, correctly detecting the runtime environment (CI, Codespaces, etc.)
  // Pinned by digest only (no tag): the devcontainers CLI cannot parse a
  // combined `:tag@sha256:...` reference, so Renovate keeps just the digest.
  "image": "ghcr.io/devsecninja/dotfiles-devcontainer@sha256:9cb0b77faf68c15cf50ef273e8dd5f5d8350609340a6569d82484c744cd108bb",
  "features": {
    "ghcr.io/devcontainers/features/git-lfs:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/powershell:2": {
      "modules": "Pester==5.7.1"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "pspester.pester-test"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.eol": "\n",
        "terminal.integrated.defaultProfile.linux": "fish"
      }
    }
  },
  "postCreateCommand": "./home/install.sh",
  // Re-point chezmoi at this workspace. The shared prebuilt image and the
  // user-level VS Code "dotfiles" feature both leave chezmoi sourced from
  // ~/.dotfiles; this runs after the dotfiles install on every start so edits
  // in /workspaces/dotfiles are the chezmoi source of truth.
  "postStartCommand": "bash .devcontainer/postStart.sh ${containerWorkspaceFolder}/home",
  // Put the mise shims dir on PATH for the whole VS Code server so git hooks
  // launched from the Source Control panel (which inherit this environment)
  // resolve shellcheck/shfmt/cog/lefthook the same way the terminal does. The
  // shims are self-contained (symlinks to the mise binary), so no separate
  // `mise` entry is required.
  "remoteEnv": {
    "PATH": "${containerEnv:HOME}/.local/share/mise/shims:${containerEnv:PATH}"
  },
  "remoteUser": "vscode"
}
